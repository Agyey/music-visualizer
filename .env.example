# ─────────────────────────────────────────────────────────────────────────────
# Music Visualizer — Environment Variables Reference
# Copy this file to .env (never commit .env)
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────────────────────

# Server
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Authentication (JWT)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-at-least-32-char-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL=900       # seconds (15 min)
REFRESH_TOKEN_TTL=604800   # seconds (7 days)

# OAuth — Google
# https://console.developers.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
# https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth redirect base (public backend URL)
OAUTH_REDIRECT_BASE=http://localhost:8000

# Database (Neon PostgreSQL)
# Format: postgresql+asyncpg://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Error monitoring (Sentry)
# https://sentry.io/
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Frontend ──────────────────────────────────────────────────────────────────

VITE_API_URL=http://localhost:8000
VITE_SENTRY_DSN=

# ── CI / Railway ─────────────────────────────────────────────────────────────

# Used by GitHub Actions deploy job
RAILWAY_TOKEN=
